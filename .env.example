# ═══════════════════════════════════════════════════════════
# BookGyaan AI Video Generator — Environment Variables
# ═══════════════════════════════════════════════════════════
# Copy this file as .env and fill in your API keys

# ─── LLM Provider ───────────────────────────────────────
# Options: "gemini" (free) or "openai" (paid)
LLM_PROVIDER=gemini

# Google Gemini API Key (FREE at https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API Key (optional, paid — https://platform.openai.com/api-keys)
OPENAI_API_KEY=your_openai_api_key_here

# ─── Image Generation ──────────────────────────────────
# Options: "dalle" (paid, needs OpenAI key), "pexels" (free stock), "placeholder" (local)
IMAGE_PROVIDER=placeholder

# Pexels API Key (FREE at https://www.pexels.com/api/)
PEXELS_API_KEY=your_pexels_api_key_here

# ─── TTS Voice ─────────────────────────────────────────
# Female: "hi-IN-SwaraNeural"  |  Male: "hi-IN-MadhurNeural"
TTS_VOICE=hi-IN-SwaraNeural
TTS_RATE=+0%

# ─── YouTube Upload (optional) ─────────────────────────
# Path to OAuth client_secrets.json from Google Cloud Console
YOUTUBE_CLIENT_SECRETS=client_secrets.json
